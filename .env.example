# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
PROGRAM_ID=75vZMouaNixrw4zk1rohwMyHCkPZU7odD5crg6goWjM6
TREASURY_PUBKEY=YOUR_PHANTOM_WALLET_PUBKEY

# Path to deployer keypair — upload as a Secret File at this path on Render
SERVER_KEYPAIR=/etc/secrets/id.json

# ── Key system ────────────────────────────────────────────────────────────────
PORTAL_KEYS_ENABLED=true

# Optional: pre-loaded gifted keys (comma-separated, survive restarts)
# ADMIN_KEYS=KEY1XXXX,KEY2XXXX

# Admin endpoint secret — generate with: openssl rand -hex 32
ADMIN_SECRET=replace_with_random_secret

# ── Face service ──────────────────────────────────────────────────────────────
# After portal-face deploys on Render, paste its URL here
FACE_SERVICE_URL=https://portal-face.onrender.com

# ── TURN server (needed for connections across NAT/firewalls) ─────────────────
TURN_URL_UDP=turn:YOUR_VPS_IP:3478?transport=udp
TURN_URL_TCP=turn:YOUR_VPS_IP:3478?transport=tcp
TURN_USERNAME=portal
TURN_CREDENTIAL=your_turn_password

# ── Local dev only ────────────────────────────────────────────────────────────
PORT=3000
